# apps/web is a static marketing site with no backend of its own — see
# src/lib/waitlist-service.ts. No environment variables are currently
# required to build or run it. This file exists so the convention (every
# app in this monorepo documents its config surface, even an empty one)
# holds, and as a placeholder for when a real waitlist backend/email
# provider is wired in.

# Public site URL, used for absolute canonical/OpenGraph URLs
# (src/app/layout.tsx, src/app/sitemap.ts, src/app/robots.ts). Falls back
# to https://enizamusic.dev when unset.
NEXT_PUBLIC_SITE_URL=https://enizamusic.dev
