{
  "expo": {
    "name": "Music App (working title)",
    "slug": "music-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "../../assets/app-icon/icon-1024.png",
    "scheme": "musicapp",
    "userInterfaceStyle": "automatic",
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "../../assets/app-icon/icon-1024.png",
        "monochromeImage": "../../assets/branding/logo/eniza-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.musicapp"
    },
    "web": {
      "output": "static",
      "favicon": "../../assets/favicon/favicon-512.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "../../assets/splash/splash-logo.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
