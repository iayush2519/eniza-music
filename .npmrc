# React Native's Metro bundler does not fully support pnpm's default
# symlinked node_modules structure (it doesn't implement Node's package
# exports/symlink resolution the same way Node itself does). Hoisting
# node_modules avoids a class of "module not found" / duplicate-package
# errors in apps/mobile. This trades some of pnpm's strict isolation for
# React Native ecosystem compatibility, which is the standard, documented
# approach for RN + pnpm monorepos.
node-linker=hoisted
strict-peer-dependencies=false
auto-install-peers=true
