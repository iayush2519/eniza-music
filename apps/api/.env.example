# Copy to .env for local development. Never commit .env (see .gitignore
# and docs/architecture/security.md).

NODE_ENV=development
PORT=3000

# Matches the postgres service in the repo-root docker-compose.yml.
DATABASE_URL=postgresql://music_app:music_app@localhost:5432/music_app

# Generate real secrets locally, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Must be at least 32 characters. Access and refresh secrets must differ so
# a leaked access token can never be used to mint a new refresh token.
JWT_ACCESS_SECRET=replace-with-a-random-secret-at-least-32-characters-long
JWT_REFRESH_SECRET=replace-with-a-different-random-secret-at-least-32-chars

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
