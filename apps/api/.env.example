# Copy to .env for local development. Never commit .env (see .gitignore
# and docs/architecture/security.md).

NODE_ENV=development
PORT=3000

# Matches the postgres service in the repo-root docker-compose.yml.
DATABASE_URL=postgresql://music_app:music_app@localhost:5432/music_app

# Generate real secrets locally, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Must be at least 32 characters. Access and refresh secrets must differ so
# a leaked access token can never be used to mint a new refresh token.
JWT_ACCESS_SECRET=replace-with-a-random-secret-at-least-32-characters-long
JWT_REFRESH_SECRET=replace-with-a-different-random-secret-at-least-32-chars

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Jamendo (https://developer.jamendo.com) is the first real MusicProvider
# — see docs/architecture/music-provider-architecture.md. Get a free
# client id at https://devportal.jamendo.com. Optional: when unset,
# DiscoveryModule falls back to the in-memory MockProvider so local dev
# and tests never require a real API key.
JAMENDO_CLIENT_ID=
JAMENDO_API_BASE_URL=https://api.jamendo.com/v3.0

# Matches the redis service in the repo-root docker-compose.yml. Backs
# the metadata-refresh job queue. Optional: when unset, DiscoveryModule
# falls back to an in-process inline queue so local dev and tests never
# require a running Redis instance.
REDIS_URL=redis://localhost:6379
